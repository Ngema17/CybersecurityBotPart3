<Window x:Class="CybersecurityBotPart3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Awareness Bot" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#12192D"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Button Styles -->
        <Style x:Key="TaskButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3278C8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A8CD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuizButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34CE57"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFA500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB733"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3278C8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,0,10,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A8CD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#C84646"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E05555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER PANEL ========== -->
        <Border Grid.Row="0" 
                Background="#1C2337" 
                BorderBrush="#2A3348" 
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left side - Title and Status -->
                <StackPanel Margin="20,15,0,0">
                    <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="[ SAFE • SMART • SECURE ]" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Foreground="#64C864"
                               Margin="0,5,0,0"/>
                    <TextBlock x:Name="StatusText" 
                               Text="● Ready" 
                               FontSize="11" 
                               Foreground="#64C864"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Right side - Feature Buttons -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Margin="0,15,15,0" 
                            VerticalAlignment="Top">

                    <!-- Task Button -->
                    <Button x:Name="TaskButton" 
                            Content="📋 Tasks"
                            Style="{StaticResource TaskButtonStyle}"/>

                    <!-- Quiz Button -->
                    <Button x:Name="QuizButton" 
                            Content="🎯 Quiz"
                            Style="{StaticResource QuizButtonStyle}"/>

                    <!-- Log Button -->
                    <Button x:Name="LogButton" 
                            Content="📊 Log"
                            Style="{StaticResource LogButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CHAT DISPLAY AREA ========== -->
        <Border Grid.Row="1" Background="#1E2537">
            <ScrollViewer x:Name="ChatScrollViewer" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ChatPanel" 
                            Margin="15" 
                            Orientation="Vertical"/>
            </ScrollViewer>
        </Border>

        <!-- ========== INPUT PANEL ========== -->
        <Border Grid.Row="2" 
                Background="#1C2337" 
                BorderBrush="#2A3348" 
                BorderThickness="0,2,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Text Input -->
                <TextBox x:Name="UserInputBox" 
                         Grid.Column="0"
                         Height="40"
                         FontSize="14"
                         Background="#28334A"
                         Foreground="White"
                         BorderBrush="#3D4A6B"
                         BorderThickness="1"
                         Padding="10,0,10,0"
                         VerticalContentAlignment="Center"
                         CaretBrush="White"
                         TextWrapping="Wrap">
                    <TextBox.Resources>
                        <VisualBrush x:Key="HintText" 
                                     Visual="{Binding ElementName=HintBlock}" 
                                     AlignmentX="Left" 
                                     AlignmentY="Center"
                                     Stretch="None"/>
                        <TextBlock x:Key="HintBlock" 
                                   Text="Type your message here... (type 'exit' to close)" 
                                   Foreground="Gray"
                                   Background="Transparent"
                                   FontSize="12"/>
                    </TextBox.Resources>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                          Background="Transparent"/>
                                            <Border x:Name="HintBorder" 
                                                    Background="Transparent"
                                                    IsHitTestVisible="False">
                                                <ContentPresenter Content="{StaticResource HintText}" 
                                                                  Margin="10,0,0,0"
                                                                  Visibility="Collapsed"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter TargetName="HintBorder" 
                                                        Property="Visibility" 
                                                        Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Send Button -->
                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="📤 SEND"
                        Style="{StaticResource SendButtonStyle}"/>

                <!-- Exit Button -->
                <Button x:Name="ExitButton" 
                        Grid.Column="2"
                        Content="❌ EXIT"
                        Style="{StaticResource ExitButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>